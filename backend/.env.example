# Backend environment (for local development)
# Run `./scripts/setup.sh` from the project root to generate this file automatically.

PORT=3001
NODE_ENV=development
DATABASE_PATH=./data/computerzentrale.db

# Encryption secret — used for SSH key encryption and JWT tokens
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=

# App password — protects the web interface (leave empty to disable)
APP_PASSWORD=

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=computerzentrale
INFLUXDB_BUCKET=ping_metrics

# Redis (for caching SSH command results)
REDIS_URL=redis://localhost:6379

# Server metrics collection interval in seconds (default: 10)
SERVER_METRICS_INTERVAL=10
