# ============================================
# Computerzentrale Environment Configuration
# ============================================
# Run `./scripts/setup.sh` to generate this file automatically.

# Encryption secret — used for SSH key encryption and JWT tokens
# Generate with: openssl rand -hex 32
# CRITICAL: Do not change after initial setup (encrypted data becomes unreadable)
ENCRYPTION_SECRET=

# App password — protects the web interface (leave empty to disable)
APP_PASSWORD=

# InfluxDB — time-series database for metrics history
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=computerzentrale
INFLUXDB_BUCKET=ping_metrics
INFLUXDB_ADMIN_PASSWORD=

# Server port (default: 3001)
# PORT=3001

# Server metrics collection interval in seconds (default: 10)
# SERVER_METRICS_INTERVAL=10
